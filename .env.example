# Airflow runtime and executor
AIRFLOW_UID=50000
AIRFLOW_GID=50000
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__WORKERS=2

# Database connections for report generation
MT_POSTGRES_HOST=mt-postgres
MT_POSTGRES_PORT=5432
POSTGRES_DB=mt-pg
POSTGRES_USER=user
POSTGRES_PASSWORD=password
MT_MYSQL_HOST=mt-mysql
MT_MYSQL_PORT=3306
MYSQL_DATABASE=mt-mysql
MYSQL_ROOT_PASSWORD=password

# Airflow admin credentials
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com

# AWS and SES settings
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=__AWS_ACCESS_KEY_ID__
AWS_SECRET_ACCESS_KEY=__AWS_SECRET_ACCESS_KEY__
S3_REPORT_BUCKET=__S3_REPORT_BUCKET__
S3_REPORT_PREFIX=__S3_REPORT_PREFIX__
SES_SENDER=__SES_SENDER__
SES_RECIPIENTS=__SES_RECIPIENTS__
